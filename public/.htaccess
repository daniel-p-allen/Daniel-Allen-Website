# Apache configuration for the built site.
#
# Vite copies everything in public/ to the root of dist/, so this file ends up
# alongside index.html on the web host.

# ---------------------------------------------------------------------------
# Which file is the home page
# ---------------------------------------------------------------------------
# Apache serves index.php ahead of index.html by default. The host this deploys to
# had an unrelated index.php sitting in the web root, so the site appeared blank
# even once index.html was uploaded correctly. Naming index.html first settles it.
DirectoryIndex index.html index.php

# ---------------------------------------------------------------------------
# Routing
# ---------------------------------------------------------------------------
# Each route is prerendered to its own HTML file at build time, so /about and
# /portfolio are real pages with their own titles, descriptions and content —
# readable by anything that does not run JavaScript.
#
# Only the routes that exist are mapped. There is deliberately no catch-all: an
# earlier version sent every unmatched path to index.html, so a typo or a stale
# link returned 200 with the full home page. Search engines call that a soft 404
# and treat it as a quality problem, because it means infinitely many URLs all
# claim to be a valid page. Unknown paths now return a real 404.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Real files — assets, robots.txt, sitemap.xml — are served untouched.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # The two routes that are not the home page, with or without a trailing slash.
  RewriteRule ^about/?$ /about.html [L]
  RewriteRule ^portfolio/?$ /portfolio.html [L]
</IfModule>

# Unknown paths get the home page as their 404 body, but with a 404 status, so a
# visitor sees something useful and a crawler is told the truth.
ErrorDocument 404 /index.html

# ---------------------------------------------------------------------------
# Caching
# ---------------------------------------------------------------------------
# The build gives every asset a content hash in its filename (index-0aa94999.js),
# so a changed file is always a new name. Those can be cached hard and forever.
# index.html must never be cached, or visitors keep loading an old page that
# points at assets which no longer exist.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|jpe?g|png|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ---------------------------------------------------------------------------
# Compression
# ---------------------------------------------------------------------------
# Text assets compress well — the JavaScript bundle is 86KB raw and 34KB gzipped.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
